# ============================================================
# Variáveis de ambiente — Sistema EYE Agência (frontend)
# Copie este arquivo para ".env" e preencha as chaves.
# ============================================================

# URL base da API (backend Fastify). Em produção, aponte para o domínio público.
VITE_API_URL=http://127.0.0.1:3333/api/v1

# OpenAI — geração de imagem, legenda e roteiro.
# (Em produção, prefira um proxy no back-end e NÃO exponha a chave no front.)
VITE_OPENAI_API_KEY=

# Disparo de postagens (WhatsApp Cloud API / e-mail / webhook).
# Endpoint que receberá o payload no horário agendado.
VITE_DISPATCH_WEBHOOK_URL=
